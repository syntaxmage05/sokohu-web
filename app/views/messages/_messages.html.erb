<%= tag.messages_container id: dom_id(conversation, :messages),
        data: {
            controller: "messages",
            messages_recipient_value: Current.organization.id,
            messages_sender_class:
              "has-background-primary-dark has-text-white"
        },
        class: "p-4" do 
%>
  <%= render conversation.messages.for_display %>
  <%= turbo_stream_from @conversation, channel: "ConversationsChannel"%>
<% end %>