<layout-columns class="columns is-centered">
  <%= form_with(
        model: @listing,
        class: "column is-10",
        id: "edit_listing_form"
    ) do |form| %>
    <%= render "listings/form", form: form %>
  <% end %>
</layout-columns>
<layout-columns class="columns is-centered">
  <layout-column class="column is-10">
    <layout-group class="buttons is-right">
      <%= button_to t(".delete"), listing_path(@listing), 
              form: {data: {turbo_confirm: t(".confirm_delete")}}, 
              method: :delete, 
              class: "button is-danger is-medium m-3"\
                unless turbo_native_app?  
        %>
      <% if @listing.draft? %>
        <%= submit_tag t(".update"),
                form: "edit_listing_form",
                formaction: listing_draft_path(@listing),
                class: "button is-secondary is-medium m-3"
          %>
      <% end %>
      <%= submit_tag t(".publish"), form: "edit_listing_form", class: "button is-primary is-medium m-3" %>
    </layout-group>
  </layout-column>
</layout-columns>